# Howe Sound DJ — inquiry email (Resend). Copy to `.env.local` for local testing.
# Production: set these in Vercel → Project → Settings → Environment Variables.

# Resend API key (https://resend.com → API Keys).
RESEND_API_KEY=re_your_key_here

# Where inquiries land (Patrick’s inbox; Gmail).
CONTACT_TO_EMAIL=patrick@howesounddj.com

# “From” address Resend will send as. Must be on a domain you have verified in Resend
# (e.g. hello@howesounddj.com). If the domain or address isn’t verified, sends fail.
CONTACT_FROM_EMAIL=hello@howesounddj.com
