# Howe Sound DJ — copy to `.env.local` for local dev when needed.
# Production: set vars in Vercel → Project → Settings → Environment Variables.

# --- Governed availability (HSDJ Operations) — server-side only ---
# Same-origin `/api/availability` proxies to this endpoint. No Google credentials on the website.
HSDJ_OPERATIONS_AVAILABILITY_API_URL=https://ops.howesounddj.com/api/availability

# --- Optional: Google Analytics 4 ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Inquiry email (Resend) — required for “Send inquiry” on /contact ---
RESEND_API_KEY=re_your_key_here
CONTACT_TO_EMAIL=patrick@howesounddj.com
CONTACT_FROM_EMAIL=hello@howesounddj.com

# --- Cloudflare Turnstile — required for inquiry submit (server verifies token) ---
TURNSTILE_SITE_KEY=your_site_key_here
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here
